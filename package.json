{
  "name": "my-jarvis-dashboard-__TENANT__",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p functions/tsconfig.json",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"functions/**/*.{ts,tsx}\"",
    "lint:apply": "eslint \"src/**/*.{ts,tsx}\" \"functions/**/*.{ts,tsx}\" --fix",
    "smoke": "node scripts/smoke.mjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name my-jarvis-dashboard-__TENANT__ --branch main --commit-dirty=true"
  },
  "dependencies": {
